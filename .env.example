# Database
DB_USER=officeping
DB_PASSWORD=officeping
DB_NAME=officeping

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRY=7d

# Google OAuth — Web client ID from Google Cloud Console.
# Authorized JavaScript origins must include: http://localhost, http://localhost:5173
GOOGLE_CLIENT_ID=
ALLOWED_EMAIL_DOMAIN=questionpro.com
ADMIN_EMAILS=fahim.hasnat@questionpro.com

# Demo mode — enables POST /auth/demo-login with seeded demo users (judging escape
# hatch; the app is fully usable without a Google OAuth client when this is true)
DEMO_MODE=true

# VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@officeping.local

# Public URL of your deployment (used in push notification action callbacks)
# For local docker: http://localhost  |  For production: https://yourdomain.com
API_BASE_URL=http://localhost
WEB_ORIGIN=http://localhost

# Frontend (local dev — in docker these are injected as build args)
VITE_API_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=
VITE_VAPID_PUBLIC_KEY=
VITE_DEMO_MODE=true
